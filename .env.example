# ─── Alpaca Paper Trading ─────────────────────────────────────────
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Claude AI (Anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ─── Webhook Guvenlik ────────────────────────────────────────────
WEBHOOK_SECRET=buraya-guclu-bir-sifre-yaz

# ─── Uygulama Ayarlari ──────────────────────────────────────────
PORT=8000
MAX_RISK_PCT=0.02
AI_APPROVAL_REQUIRED=false

# ─── Broad Scan (V5.5) — İki Aşamalı Tarama ────────────────────
# KAPALI default. Açmak için true yap:
#   BROAD_SCAN_ENABLED=true
# Açıldığında NASDAQ 100 + Core 15 taranır, pre-filter'dan geçenler
# top N'e indirgenir ve Claude'a gönderilir. Core 15 her zaman dahil.
BROAD_SCAN_ENABLED=false

# Pre-filter eşikleri (Core 15 bunları bypass eder)
PREFILTER_MIN_PRICE=10.0
PREFILTER_MIN_AVG_VOLUME=1000000
PREFILTER_MIN_CHANGE_PCT=2.0
PREFILTER_MIN_VOL_RATIO=1.3
PREFILTER_TOP_N=20

# ─── Akilli Zamanlayici (V5.6) — Adaptive Scan ───────────────
# AÇIK default. Tarama sıklığını günün saatine göre ayarlar:
#   Market açık (9:30-16 ET):  her 5 dk
#   Pre-market   (4-9:30 ET):  her 15 dk
#   After-hours  (16-20 ET):   her 30 dk
#   Gece         (20-4 ET):    her 60 dk
#   Hafta sonu:                her 180 dk (3 saat)
# Tasarruf: ~%40 maliyet düşüşü (~$230/ay)
# Kapatmak için false yap (eski 10 dk her zaman):
SMART_SCHEDULE_ENABLED=true
SMART_INTERVAL_MARKET=5
SMART_INTERVAL_PREMARKET=15
SMART_INTERVAL_AFTERHOURS=30
SMART_INTERVAL_NIGHT=60
SMART_INTERVAL_WEEKEND=180
